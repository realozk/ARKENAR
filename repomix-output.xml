/* 🪐 Cosmic — Deep Space Mystery */
[data-theme="cosmic"] {
  --color-bg-root: #0b071a;
  --color-bg-panel: #130d2b;
  --color-bg-terminal: #070412;
  --color-bg-card: rgba(139, 92, 246, 0.08);
  /* Violet tint */
