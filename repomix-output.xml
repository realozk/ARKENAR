/* ── Light: terminal hover row ───────────────────────────────── */
[data-theme="light"] .terminal-line:hover {
  background: rgba(0, 0, 0, 0.05);
}

/* ── Light: inactive tab text — make it clearly readable ─────── */
[data-theme="light"] .text-text-ghost {
  color: var(--color-text-ghost);
}

/* ── Light: active tab pill needs a visible shadow ───────────── */
[data-theme="light"] .bg-bg-hover {
