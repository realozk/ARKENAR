@import "tailwindcss";

/* ─── Arkenar Premium Design System — Linear-inspired ────────── */
@theme {
  /* Surfaces — warmer, slightly lifted dark palette */
  --color-bg-root: #0a0a0c;
  --color-bg-panel: #111114;
  --color-bg-card: rgba(255, 255, 255, 0.035);
  --color-bg-input: #151518;
  --color-bg-hover: rgba(255, 255, 255, 0.06);
  --color-bg-terminal: #08080a;

  /* Borders — soft, glass-like */
  --color-border-subtle: rgba(255, 255, 255, 0.08);
  --color-border-hover: rgba(255, 255, 255, 0.12);
  --color-border-focus: rgba(0, 213, 190, 0.4);

  /* Text — lifted for readability */
  --color-text-primary: #e1e1e6;
  --color-text-secondary: #94949e;
  --color-text-muted: #64647a;
  --color-text-ghost: #3e3e52;

  /* Accent — orange brand */
  --color-accent: #EA580C;
  --color-accent-dim: rgba(234, 88, 12, 0.10);
  --color-accent-hover: #F97316;
  --color-accent-text: #EA580C;

  /* Status */
  --color-status-critical: #f43f5e;
  --color-status-warning: #eab308;
  --color-status-success: #10b981;
  --color-status-info: #EA580C;
  --color-status-idle: #444460;

  /* Shadows */
  --shadow-card: 0 1px 3px rgba(0, 0, 0, 0.5);
  --shadow-accent-glow: 0 0 24px rgba(234, 88, 12, 0.12), 0 0 48px rgba(234, 88, 12, 0.04);
  --shadow-accent-btn: 0 0 20px rgba(234, 88, 12, 0.2), 0 0 40px rgba(234, 88, 12, 0.06);

  /* Font stacks */
  --font-sans: "Space Grotesk", system-ui, -apple-system, sans-serif;
  --font-mono: "JetBrains Mono", "Fira Code", ui-monospace, monospace;

  /* Glass/Gradient Overlays */
  --glass-tint: rgba(255, 255, 255, 0.035);
  --glass-border: rgba(255, 255, 255, 0.08);
  --glass-blur: blur(12px);
  --gradient-overlay: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.05), transparent 70%);
}

/* ─── Themes ─────────────────────────────────────────────────── */

/* 🌌 Dark — Original Premium */
[data-theme="dark"] {
  --color-bg-root: #0a0a0c;
  --color-bg-panel: #111114;
  --color-bg-terminal: #08080a;
  --color-bg-card: rgba(255, 255, 255, 0.035);
  --gradient-surface: linear-gradient(180deg, #121216 0%, #0d0d10 100%);
}

/* ☀️ Light — Clean White Studio */
[data-theme="light"] {
  /* Main wrapper is transparent — canvas shines through */
  --color-bg-root: transparent;
  /* Panels are frosted glass */
  --color-bg-panel: rgba(255, 255, 255, 0.22);
  --color-bg-terminal: rgba(255, 255, 255, 0.18);
  --color-bg-card: rgba(255, 255, 255, 0.18);
  --color-bg-input: rgba(255, 255, 255, 0.55);
  --color-bg-hover: rgba(0, 0, 0, 0.06);

  --color-border-subtle: rgba(0, 0, 0, 0.11);
  --color-border-hover: rgba(0, 0, 0, 0.18);

  --color-text-primary: #0e0e14;
  --color-text-secondary: #42424e;
  --color-text-muted: #72728a;
  --color-text-ghost: #8e8ea8;

  --color-status-idle: #b0b0c8;

  --shadow-card: 0 1px 4px rgba(0, 0, 0, 0.10);
  --shadow-accent-glow: 0 0 24px rgba(0, 213, 190, 0.10), 0 0 48px rgba(0, 213, 190, 0.04);
  --shadow-accent-btn: 0 0 20px rgba(0, 213, 190, 0.18), 0 0 40px rgba(0, 213, 190, 0.06);

  --gradient-surface: linear-gradient(180deg, rgba(255, 255, 255, 0.82) 0%, rgba(245, 247, 250, 0.78) 100%);
  --glass-tint: rgba(255, 255, 255, 0.25);
  --glass-border: rgba(0, 0, 0, 0.10);
}

/* html gets the ambient page colour — canvas draws ABOVE this.
   Body must NOT have a background or it paints over the canvas. */
[data-theme="light"] html {
  background: #d8dae2;
}

[data-theme="light"] body {
  background: transparent;
}


/* ── Light: scrollbar ─────────────────────────────────────────── */
[data-theme="light"] ::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.18);
}

[data-theme="light"] ::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 0, 0, 0.30);
}

/* ── Light: body — transparent so canvas shows, use white glass tint ─ */
[data-theme="light"] body {
  background-image: none;
}

/* ── Light: glass containers — frosted glass with blur ─────────── */
[data-theme="light"] aside,
[data-theme="light"] header,
[data-theme="light"] .settings-panel,
[data-theme="light"] .finding-card {
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
