        let payloads = loader.get_payloads_for_point(&InjectionPoint::Header("User-Agent".to_string()));
        assert!(!payloads.is_empty());
        assert!(payloads.iter().any(|p| p.contains("OR")));
    }

    #[test]
    fn test_all_polyglots() {
