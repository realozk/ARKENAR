{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arkenar",
  "version": "1.0.4",
  "identifier": "com.real0zk.arkenar",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
     {
  "title": "Arkenar",
  "width": 1280,
  "height": 800,
  "minWidth": 900,
  "minHeight": 600,
  "resizable": true,
  "decorations": false,
  "transparent": true,
  "shadow": true,
  "theme": "Dark"

}
    ],
    "security": {
"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost/",
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
   "nsis": {
  "installerIcon": "icons/icon.ico",
  "sidebarImage": "icons/sidebar.bmp",
  "headerImage": "icons/header.bmp",
  "installMode": "currentUser",
  "displayLanguageSelector": false
}

    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/realozk/ARKENAR/main/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMwREEzNEI0RjY2OTI2MzEKUldReEptbjJ0RFRhd0tvUy9xZHpOKzU2M1FkOS90MEFhOUdWZFc2am84ZDJydWhKbHpXeWVkL2cK"
    }
  }
}